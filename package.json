{
  "name": "tinymoon",
  "version": "0.4.0",
  "description": "Zero-dependency vanilla JS/CSS UI framework",
  "license": "MIT",
  "type": "module",
  "main": "./assets/js/index.js",
  "types": "./assets/js/index.d.ts",
  "exports": {
    ".": {
      "types": "./assets/js/index.d.ts",
      "default": "./assets/js/index.js"
    },
    "./extras": {
      "types": "./assets/js/extras.d.ts",
      "default": "./assets/js/extras.js"
    },
    "./assets/*": "./assets/*"
  },
  "files": [
    "assets",
    "CHANGELOG.md"
  ],
  "repository": "github:smm-h/tinymoon",
  "author": "smm-h",
  "keywords": [
    "ui",
    "framework",
    "vanilla-js",
    "css",
    "zero-dependency",
    "rlsbl"
  ],
  "scripts": {
    "test": "./scripts/check-js-syntax.sh && vitest run && npm run test:types",
    "test:types": "tsc --noEmit -p tests/types",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "happy-dom": "^20.10.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
