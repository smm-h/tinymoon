{
  "name": "tinymoon",
  "version": "0.7.0",
  "description": "Zero-dependency vanilla JS/CSS UI framework",
  "license": "MIT",
  "type": "module",
  "main": "./assets/js/index.js",
  "types": "./assets/js/index.d.ts",
  "exports": {
    ".": {
      "types": "./assets/js/index.d.ts",
      "default": "./assets/js/index.js"
    },
    "./extras": {
      "types": "./assets/js/extras.d.ts",
      "default": "./assets/js/extras.js"
    },
    "./state": {
      "types": "./assets/js/state.d.ts",
      "default": "./assets/js/state.js"
    },
    "./chrome": {
      "types": "./assets/js/chrome.d.ts",
      "default": "./assets/js/chrome.js"
    },
    "./widgets": {
      "types": "./assets/js/widgets.d.ts",
      "default": "./assets/js/widgets.js"
    },
    "./accordion": "./assets/js/accordion.js",
    "./auditor": "./assets/js/auditor.js",
    "./badge": "./assets/js/badge.js",
    "./breadcrumbs": "./assets/js/breadcrumbs.js",
    "./chart": "./assets/js/chart.js",
    "./combobox": "./assets/js/combobox.js",
    "./controls": "./assets/js/controls.js",
    "./ctxmenu": "./assets/js/ctxmenu.js",
    "./datepicker": "./assets/js/datepicker.js",
    "./dismiss": "./assets/js/dismiss.js",
    "./dom": "./assets/js/dom.js",
    "./drawer": "./assets/js/drawer.js",
    "./embed": "./assets/js/embed.js",
    "./feed": "./assets/js/feed.js",
    "./filterbar": "./assets/js/filterbar.js",
    "./format": "./assets/js/format.js",
    "./grid": "./assets/js/grid.js",
    "./hovercard": "./assets/js/hovercard.js",
    "./iconbutton": "./assets/js/iconbutton.js",
    "./icons": "./assets/js/icons.js",
    "./inputs": "./assets/js/inputs.js",
    "./kernel": "./assets/js/kernel.js",
    "./lazy": "./assets/js/lazy.js",
    "./markdown": "./assets/js/markdown.js",
    "./modal": "./assets/js/modal.js",
    "./net": "./assets/js/net.js",
    "./paginate": "./assets/js/paginate.js",
    "./palette": "./assets/js/palette.js",
    "./popover": "./assets/js/popover.js",
    "./realtime": "./assets/js/realtime.js",
    "./select": "./assets/js/select.js",
    "./settings": "./assets/js/settings.js",
    "./shell": "./assets/js/shell.js",
    "./shortcuts": "./assets/js/shortcuts.js",
    "./slider": "./assets/js/slider.js",
    "./sparkline": "./assets/js/sparkline.js",
    "./states": "./assets/js/states.js",
    "./stats": "./assets/js/stats.js",
    "./store": "./assets/js/store.js",
    "./table": "./assets/js/table.js",
    "./tabpanels": "./assets/js/tabpanels.js",
    "./timepicker": "./assets/js/timepicker.js",
    "./toast": "./assets/js/toast.js",
    "./tooltip": "./assets/js/tooltip.js",
    "./tree": "./assets/js/tree.js",
    "./view": "./assets/js/view.js",
    "./virtuallist": "./assets/js/virtuallist.js",
    "./wiki": "./assets/js/wiki.js",
    "./assets/*": "./assets/*"
  },
  "files": [
    "assets",
    "CHANGELOG.md"
  ],
  "repository": "github:smm-h/tinymoon",
  "author": "smm-h",
  "keywords": [
    "ui",
    "framework",
    "vanilla-js",
    "css",
    "zero-dependency",
    "rlsbl"
  ],
  "scripts": {
    "test": "./scripts/check-js-syntax.sh && vitest run && npm run test:types",
    "test:types": "tsc --noEmit -p tests/types",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "happy-dom": "^20.10.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
